# ─────────────────────────────────────────────────────────────────────────────
# NexMind + Nextcloud — Environment Variables
# Copy this file to .env and fill in your values before running docker compose
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude AI ─────────────────────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Nextcloud Admin Credentials ───────────────────────────────────────────────
# These are set on first Nextcloud initialization
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_nextcloud_pass

# ── MariaDB (Nextcloud database) ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_pass
MYSQL_PASSWORD=change_me_mysql_pass

# ── Webhook Security ──────────────────────────────────────────────────────────
# Shared secret between Nextcloud Flow and NexMind — prevents unauthorized calls.
# Generate a random value with: openssl rand -hex 32
WEBHOOK_SECRET=change_me_webhook_secret_32chars
