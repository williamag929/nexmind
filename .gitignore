mariadb_data/
nextcloud_data/
nextcloud_config/
nextcloud_apps/
nexmind_db/
nexmind_uploads/

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Build artifacts ────────────────────────────────────────
dist/
build/
coverage/

# ── SSL certs (if added later) ─────────────────────────────
nginx/ssl/
*.pem
*.key
*.crt
