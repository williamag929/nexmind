# ── Node ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Environment — NEVER commit secrets ────────────────────
.env
.env.local
.env.*.local

# ── NexMind runtime data ───────────────────────────────────
db/                  # SQLite database files
uploads/             # uploaded files (multer temp)

